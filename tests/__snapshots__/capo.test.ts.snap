    "meta[name=viewport]",
    "base[href=https://example.com/]",
    "meta[name=referrer]",
    "title",
    "link[rel=preconnect;href=https://cdn.example.com]",
    "link[rel=dns-prefetch;href=//cdn.example.com]",
    "link[rel=preload;href=/font.woff2;as=font]",
    "link[rel=modulepreload;href=/m.js]",
