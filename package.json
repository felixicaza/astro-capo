{
  "name": "@felixicaza/capo",
  "version": "0.0.0",
  "private": true,
  "description": "🔷🚀 Monorepo for `@felixicaza/astro-capo` and `capo-rules`.",
  "license": "MIT",
  "author": "Felix Icaza <fx.joliett17@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "oxlint . && eslint . --cache",
    "lint:fix": "oxlint . --fix --fix-suggestions --fix-dangerously && eslint . --cache --fix",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm build",
    "release": "bumpp",
    "test": "vitest",
    "test:build:fixtures": "pnpm -r build:fixture",
    "test:fixtures": "pnpm -r dev:fixture",
    "test:preview:fixtures": "pnpm -r preview:fixture",
    "typecheck": "oxlint --type-aware --type-check"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "pnpm lint:fix"
  },
  "devDependencies": {
    "@felixicaza/eslint-config": "0.1.1",
    "@felixicaza/oxlint-config": "0.1.2",
    "@felixicaza/tsdown-config": "0.1.1",
    "@types/node": "25.9.1",
    "bumpp": "11.1.0",
    "eslint": "9.39.4",
    "jiti": "2.7.0",
    "nano-staged": "1.0.2",
    "oxlint": "1.67.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
