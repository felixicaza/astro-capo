{
  "name": "@felixicaza/capo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for `@felixicaza/astro-capo` and `capo-rules`.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm -r build",
    "release": "bumpp",
    "test": "vitest",
    "test:build:fixtures": "pnpm -r build:fixture",
    "test:fixtures": "pnpm -r dev:fixture",
    "test:preview:fixtures": "pnpm -r preview:fixture"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "pnpm lint:fix"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@felixicaza/tsdown-config": "0.1.1",
    "@typescript-eslint/parser": "8.59.3",
    "bumpp": "11.1.0",
    "eslint": "9.39.1",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-yml": "3.3.2",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "nano-staged": "1.0.2",
    "neostandard": "0.13.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "author": "Felix Icaza <fx.joliett17@gmail.com>"
}
