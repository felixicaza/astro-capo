{
  "name": "@felixicaza/astro-capo",
  "version": "1.0.1",
  "description": "Automatically sort your head with capo.js in Astro",
  "keywords": [
    "astro",
    "astro-component",
    "performance",
    "capo.js",
    "head",
    "order",
    "optimization"
  ],
  "homepage": "https://github.com/felixicaza/astro-capo",
  "bugs": {
    "url": "https://github.com/felixicaza/astro-capo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixicaza/astro-capo.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm build",
    "release": "bumpp",
    "test": "vitest",
    "test:fixtures": "pnpm -r build"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "pnpm lint:fix"
  },
  "dependencies": {
    "ultrahtml": "1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@felixicaza/tsdown-config": "0.1.1",
    "@typescript-eslint/parser": "8.59.3",
    "astro": "6.3.3",
    "bumpp": "11.1.0",
    "eslint": "9.39.1",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-yml": "3.3.2",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "nano-staged": "1.0.2",
    "neostandard": "0.13.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "vitest": "4.1.6"
  },
  "sideEffects": false,
  "peerDependencies": {
    "astro": ">=2.8"
  },
  "author": "Felix Icaza <fx.joliett17@gmail.com>"
}
